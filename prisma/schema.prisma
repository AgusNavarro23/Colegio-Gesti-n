// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  // CAMBIO 1: De Role a String (y el default entre comillas)
  role      String   @default("CLIENT") 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model Escribano {
  id        String   @id @default(cuid())
  nombre    String
  matricula String   @unique
  // Controlado en Front: "Activo", "Licencia", "Jubilado"
  estado    String   @default("Activo") 
  // Controlado en Front: "Titular", "Adjunto"
  condicion String   @default("Titular")
  registroId String? 
  registro Registro? @relation(fields: [registroId], references: [numero])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Registro {
  id        String   @id @default(cuid())
  numero    String   @unique
  direccion String
  localidad String @default("Salta Capital") 
  // Controlado en Front: "Activo", "Inactivo"
  escribanos  Escribano[]
  estado    String   @default("Activo") 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}